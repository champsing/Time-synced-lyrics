{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["env.d.ts", "web2/**/*", "web2/**/*.vue"],
    "exclude": ["web2/**/__tests__/*"],
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "paths": {
            "@/*": ["./web2/*"],
            "@/components/*": ["./web2/components/*"]
        }
    }
}
